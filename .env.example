APP_NAME="Electro Vitrine"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=UTC
APP_URL=https://votre-domaine.railway.app

APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr
APP_FAKER_LOCALE=fr_FR

APP_MAINTENANCE_DRIVER=file
APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# ── Base de données (MySQL Railway) ──────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=electroshop
DB_USERNAME=root
DB_PASSWORD=

# ── Session (sécurisé pour HTTPS) ───────────────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=sync

CACHE_STORE=database
CACHE_PREFIX=

# ── Compte administrateur (seeder) ──────────────────────────────────
# CHANGEZ ces valeurs avant de déployer !
ADMIN_EMAIL=admin@electroshop.com
ADMIN_PASSWORD=VotreMotDePasseAdmin!

# ── Notifications par email ───────────────────────────────────────────
# L'admin reçoit un email à chaque nouvelle demande de commande
ADMIN_NOTIFY_EMAIL=gedeontshiangala60@gmail.com

# Fournisseur d'envoi d'email (Resend recommandé, gratuit 3000 emails/mois)
MAIL_MAILER=smtp
MAIL_HOST=smtp.resend.com
MAIL_PORT=465
MAIL_USERNAME=resend
MAIL_PASSWORD=re_VOTRE_CLE_API
MAIL_ENCRYPTION=ssl
MAIL_FROM_ADDRESS="contact@electrovitrine.cd"
MAIL_FROM_NAME="${APP_NAME}"

# ── WhatsApp (optionnel) ──────────────────────────────────────────────
# Numéro affiché aux clients sur la page contact pour commander via WhatsApp
# Format international avec le + (ex: +243844392754)
CONTACT_WHATSAPP=

VITE_APP_NAME="${APP_NAME}"
